      "updated": 1,
      "link": null,
      "locked": false,
      "text": "Security Group (nat)\nnetwork.tf\negress: all (0.0.0.0/0)\ningress: VPC's own CIDR (required for\n  forwarding) + allow_inbound_cidrs (opt-in)\nNO inbound from the internet",
      "fontSize": 15,
      "fontFamily": 2,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": "rect_13",
      "originalText": "Security Group (nat)\nnetwork.tf\negress: all (0.0.0.0/0)\ningress: VPC's own CIDR (required for\n  forwarding) + allow_inbound_cidrs (opt-in)\nNO inbound from the internet",
      "lineHeight": 1.3,
      "baseline": 114
