      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "text": "EventBridge Rule (spot_interruption)\nfailover.tf\nmatches by event type only (source + detail-type)\nnot filtered by instance/ASG \u2014 can't be,\nthe event carries only an instance ID",
      "fontSize": 15,
      "fontFamily": 2,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": "rect_31",
      "originalText": "EventBridge Rule (spot_interruption)\nfailover.tf\nmatches by event type only (source + detail-type)\nnot filtered by instance/ASG \u2014 can't be,\nthe event carries only an instance ID",
      "lineHeight": 1.3,
      "baseline": 95
    },
