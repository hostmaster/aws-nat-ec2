      "versionNonce": 1476,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "text": "Lambda: nat-failover\nfailover.tf / lambda_failover.py, python3.13\n1. is_asg_member(instance_id, ASG_NAME) \u2014 the\n   real, authoritative filter EventBridge can't do\n2. terminate_instance_in_auto_scaling_group(\n     ShouldDecrementDesiredCapacity=False)\n   -> replacement launches immediately",
      "fontSize": 15,
      "fontFamily": 2,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": "rect_33",
      "originalText": "Lambda: nat-failover\nfailover.tf / lambda_failover.py, python3.13\n1. is_asg_member(instance_id, ASG_NAME) \u2014 the\n   real, authoritative filter EventBridge can't do\n2. terminate_instance_in_auto_scaling_group(\n     ShouldDecrementDesiredCapacity=False)\n   -> replacement launches immediately",
      "lineHeight": 1.3,
      "baseline": 133
    },
