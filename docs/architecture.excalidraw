      "updated": 1,
      "link": null,
      "locked": false,
      "text": "EC2 NAT Instance\nAL2023, t3a.nano / t3.nano / t4g.nano\nbootstrap.sh.tpl at every boot:\n  ip_forward=1 + MASQUERADE (systemd oneshot)\nself, at boot: ModifyInstanceAttribute\n  (--no-source-dest-check)",
      "fontSize": 15,
      "fontFamily": 2,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": "rect_19",
      "originalText": "EC2 NAT Instance\nAL2023, t3a.nano / t3.nano / t4g.nano\nbootstrap.sh.tpl at every boot:\n  ip_forward=1 + MASQUERADE (systemd oneshot)\nself, at boot: ModifyInstanceAttribute\n  (--no-source-dest-check)",
