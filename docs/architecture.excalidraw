      "link": null,
      "locked": false,
      "text": "Launch Template (nat)\ncompute.tf\nAMI: SSM AL2023 param (x86_64/arm64)\nIMDSv2 required (hop limit 1)\nuser_data: bootstrap.sh.tpl\n  (templated: eip_allocation_id,\n   route_table_ids)",
      "fontSize": 15,
      "fontFamily": 2,
      "textAlign": "left",
      "verticalAlign": "top",
